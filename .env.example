# Frontend Supabase Integration (Vite client-side environment variables)
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend OpenAI Integration (Netlify serverless runtime environment variable)
# DO NOT prefix with VITE_ to keep it secure on the server side
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
